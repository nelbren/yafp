#!/bin/bash

DEV='ndev-'
PRO='npro-'

YAFP_REPOS=1
YAFP_TITLE=1
YAFP_ERROR=1
YAFP_PVENV=1
YAFP_CLOCK=1

# Emit OSC 133 shell-integration markers so compatible terminals can group
# each command as a semantic block. Set to 0 if your terminal misbehaves.
YAFP_OSC133=1

YAFP_DEVEL=0

# YAFP_THEME="default"
# YAFP_THEME="minimal"
YAFP_THEME="light"
